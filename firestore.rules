// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - displayName: string (required) - User's display name
//   - lastActive: string (optional) - ISO 8601 date string
//
// Collection: scores
// Document ID: {scoreId}
// Fields:
//   - uid: string (required) - User who achieved the score
//   - displayName: string (required) - User's name at the time
//   - trackId: string (required) - ID of the challenge track
//   - score: number (required) - Distance traveled (must be positive)
//   - timestamp: string (required) - ISO 8601 date string
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "chrisjbrennan23@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'lastActive', 'role']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50;
    }

    function isValidScore(data) {
      return data.keys().hasOnly(['uid', 'displayName', 'trackId', 'score', 'timestamp']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 &&
             data.trackId is string && data.trackId.size() > 0 &&
             data.score is number && data.score >= 0 &&
             data.timestamp is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /scores/{scoreId} {
      allow read: if true; // Public leaderboards
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update: if false; // Scores are immutable once submitted
      allow delete: if isAdmin();
    }
  }
}
